{
  "rewrites": [
    {
      "source": "/news/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|Discordbot|WhatsApp|TelegramBot|SkypeUriPreview|pinterest|reddit).*"
        }
      ],
      "destination": "/api/meta-proxy?path=news/:slug"
    },
    {
      "source": "/rules",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|Discordbot|WhatsApp|TelegramBot|SkypeUriPreview|pinterest|reddit).*"
        }
      ],
      "destination": "/api/meta-proxy?path=rules"
    },
    {
      "source": "/store",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|Discordbot|WhatsApp|TelegramBot|SkypeUriPreview|pinterest|reddit).*"
        }
      ],
      "destination": "/api/meta-proxy?path=store"
    },
    {
      "source": "/guide",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|Discordbot|WhatsApp|TelegramBot|SkypeUriPreview|pinterest|reddit).*"
        }
      ],
      "destination": "/api/meta-proxy?path=guide"
    },
    {
      "source": "/profile",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|Discordbot|WhatsApp|TelegramBot|SkypeUriPreview|pinterest|reddit).*"
        }
      ],
      "destination": "/api/meta-proxy?path=profile"
    },
    {
      "source": "/api/meta-proxy",
      "destination": "/api/meta-proxy"
    },
    {
      "source": "/api/:path*/",
      "destination": "https://api.mysterria.net/api/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://api.mysterria.net/api/:path*"
    },
    {
      "source": "/plan/:path*",
      "destination": "https://catwalk.mysterria.net/:path*"
    },
    {
      "source": "/catwalk/:path*",
      "destination": "https://catwalk.mysterria.net/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/game",
      "destination": "/index.html"
    },
    {
      "source": "/guide",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/login/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/rules",
      "destination": "/index.html"
    },
    {
      "source": "/edit/news",
      "destination": "/index.html"
    },
    {
      "source": "/store",
      "destination": "/index.html"
    },
    {
      "source": "/wiki",
      "destination": "/index.html"
    },
    {
      "source": "/profile/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/users",
      "destination": "/index.html"
    },
    {
      "source": "/logout",
      "destination": "/index.html"
    },
    {
      "source": "/news/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/services/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sentry",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-Sentry-Auth, Origin" }
      ]
    }
  ]
}